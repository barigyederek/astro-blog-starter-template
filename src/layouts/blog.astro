---
// Layout.astro
// This is your main layout file. Import it in your pages like:
// import Layout from '../layouts/Layout.astro'

import LogoBlack from '../assets/black.png';
import LogoWhite from '../assets/white.png';


interface Props {
  title: string;
  description?: string;
}

const { title, description = "Derek Barigye - Problem Solver" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} | Derek Barigye</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Preconnect to Google Fonts (optional, for system fonts it's not needed) -->
    <meta name="theme-color" content="#FFFFFF" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0D1117" media="(prefers-color-scheme: dark)" />
    
    <!-- Import the design system CSS -->
    <link rel="stylesheet" href="/styles/theme.css" />
    
    <!-- Additional meta tags for job/freelance SEO -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  
  <body>
    <!-- Header with Logo & Navigation -->
    <header class="header">
      <div class="container">
        <div class="header-content">
          <!-- Logo that switches based on theme -->
          <div class="logo-wrapper">
            <img 
              src={LogoBlack} 
              alt="Derek Barigye" 
              class="logo logo-light"
              width="40"
              height="40"
            />
            <img 
              src={LogoWhite} 
              alt="Derek Barigye" 
              class="logo logo-dark"
              width="40"
              height="40"
            />
          </div>
          
          <!-- Navigation -->
          <nav class="nav">
            <a href="/index.astro">Home</a>
            <a href="/projects.astro">Projects</a>
            <a href="/about.astro">About</a>
            
          </nav>
          
          <!-- Theme Toggle Button -->
          <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
            <span class="icon">🌙</span>
          </button>
        </div>
      </div>
    </header>
    
    <!-- Main Content -->
    <main class="main-content">
      <slot />
    </main>
    
    <!-- Footer -->
   <footer>
	&copy; {today.getFullYear()} Derek. All rights reserved.
	<div class="social-links">
		<a href="https://x.com/boykidongo" target="_blank">
			<span class="sr-only">Follow Derek on X</span>
			<img src="/x.png" alt="X logo" width="40" height="40" />
		</a>
		<a href="https://github.com/barigyederek" target="_blank">
			<span class="sr-only">Go to Derek's GitHub repo</span>
			<svg viewBox="0 0 16 16" aria-hidden="true" width="40" height="40" astro-icon="social/github"
				><path
					fill="currentColor"
					d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
				></path></svg
			>
		</a>
	</div>
</footer>

    <!-- Scripts for Theme Switching -->
    <script>
      // Initialize theme from localStorage or system preference
      function initializeTheme() {
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.style.colorScheme = 'dark';
          updateThemeUI('dark');
        } else {
          document.documentElement.style.colorScheme = 'light';
          updateThemeUI('light');
        }
      }

      // Update the UI based on the current theme
      function updateThemeUI(theme: string) {
        const toggle = document.getElementById('theme-toggle');
        if (toggle) {
          toggle.innerHTML = theme === 'dark' 
            ? '<span class="icon">☀️</span>' 
            : '<span class="icon">🌙</span>';
          toggle.setAttribute('data-theme', theme);
        }
      }

      // Listen for theme toggle button clicks
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const current = document.documentElement.style.colorScheme || 'light';
        const next = current === 'dark' ? 'light' : 'dark';
        
        document.documentElement.style.colorScheme = next;
        localStorage.setItem('theme', next);
        updateThemeUI(next);
      });

      // Listen for system theme changes
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
        if (!localStorage.getItem('theme')) {
          const theme = e.matches ? 'dark' : 'light';
          document.documentElement.style.colorScheme = theme;
          updateThemeUI(theme);
        }
      });

      // Initialize on page load
      initializeTheme();
    </script>
  </body>
</html>

<style>
  /* Header Styles */
  .header {
    background-color: var(--bg-primary);
    border-bottom: 1px solid var(--border-color);
    position: sticky;
    top: 0;
    z-index: 50;
    transition: all var(--transition-base);
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-lg) 0;
    gap: var(--spacing-xl);
  }

  .logo-wrapper {
    position: relative;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo {
    position: absolute;
    width: 40px;
    height: 40px;
    transition: opacity var(--transition-base);
  }

  /* Hide the appropriate logo based on theme */
  .logo-light {
    opacity: 1;
  }

  .logo-dark {
    opacity: 0;
  }

  @media (prefers-color-scheme: dark) {
    .logo-light {
      opacity: 0;
    }

    .logo-dark {
      opacity: 1;
    }
  }

  /* Navigation */
  .nav {
    display: flex;
    gap: var(--spacing-xl);
    flex: 1;
  }

  .nav a {
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--transition-fast);
    position: relative;
  }

  .nav a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--accent);
    transition: width var(--transition-fast);
  }

  .nav a:hover::after {
    width: 100%;
  }

  /* Theme Toggle Button */
  .theme-toggle {
    background: none;
    border: 1px solid var(--border-color);
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: var(--radius-md);
    cursor: pointer;
    font-size: var(--text-lg);
    transition: all var(--transition-fast);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .theme-toggle:hover {
    background-color: var(--bg-secondary);
    border-color: var(--accent);
  }

  .theme-toggle .icon {
    display: inline-block;
  }

  /* Main Content */
  .main-content {
    min-height: calc(100vh - 200px);
    padding: var(--spacing-2xl) 0;
  }

  /* Footer */
  .footer {
    background-color: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    margin-top: var(--spacing-2xl);
    padding: var(--spacing-2xl) 0;
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--spacing-xl);
  }

  .footer-content p {
    margin: 0;
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }

  .footer-links {
    display: flex;
    gap: var(--spacing-lg);
  }

  .footer-links a {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .header-content {
      gap: var(--spacing-md);
    }

    .nav {
      display: none;
    }

    .footer-content {
      flex-direction: column;
      text-align: center;
    }

    .footer-links {
      justify-content: center;
    }
  }
</style>
