---
import BaseHead_UPDATED from'../components/BaseHead_UPDATED.astro'
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import '../styles/theme.css';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>🧑‍🚀 Hello!</h1>
			<p>
				Welcome to my website! This is a place for any and all of my projects.
			</p>
			
		<p>Check out some of my <a href="/Projects">projects</a></p>
		<p>Feel free to look around and see what I've been up to.</p>
		<p>I'm always working on something new, so check back often!</p>
		
		</main>
		<Footer />
	</body>
</html>
