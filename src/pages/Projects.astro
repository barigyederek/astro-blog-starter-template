---
import BaseHead from '../components/BaseHead_UPDATED.astro';
import Header from '../components/Header_UPDATED.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { projects } from './Projects.js';
---

<html lang="en">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<link rel="stylesheet" href="/src/styles/Projects.css">
	</head>
	<body>
		<Header />
		<main>
			<h1>Projects</h1>
			<div class="projects-grid">
				{
					projects.map((project) => (
						<article class="project-card">
							<a href={project.url} target="_blank" rel="noopener noreferrer">
								<h3 class="project-title">{project.title}</h3>
								<p class="project-description">{project.description}</p>
							</a>
						</article>
					))
				}
			</div>
		</main>
		<Footer />
	</body>
</html>