---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 3em 1em;
			}
			h1 {
				margin-bottom: 1em;
				text-align: center;
			}
			.projects-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 2rem;
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.project-card {
				background-color: #ffffff;
				border-radius: 12px;
				box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
				transition: transform 0.3s ease, box-shadow 0.3s ease;
				overflow: hidden;
				display: flex;
				flex-direction: column;
				border: 1px solid #f0f0f0;
			}
			.project-card a {
				text-decoration: none;
				color: inherit;
				display: flex;
				flex-direction: column;
				height: 100%;
				padding: 1.5rem;
			}
			.project-card:hover {
				transform: translateY(-8px);
				box-shadow: 0 16px 24px rgba(0, 0, 0, 0.12);
			}
			.project-title {
				margin: 0 0 0.5rem 0;
				font-size: 1.25rem;
				color: rgb(var(--black));
			}
			.project-description {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
				line-height: 1.5;
			}
			
			@media (max-width: 1024px) {
				.projects-grid {
					grid-template-columns: repeat(3, 1fr);
				}
			}
			@media (max-width: 768px) {
				.projects-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}
			@media (max-width: 480px) {
				.projects-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
	const projects = [
  { 
    title: "IGMMS Client", 
    description: "A simple GPS tracking application.", 
    url: "https://github.com/barigyederek/igmmsClient" 
  },
  { 
    title: "Income Tax Calculator", 
    description: "A calculator to determine income tax assesments for small businesses using their gross turnover.", 
    url: "https://github.com/barigyederek/barigyederek.github.io" 
  },
  { 
    title: "Todo Task Manager", 
    description: "Full-stack todo app with user authentication and database.", 
    url: "https://github.com/barigyederek/todo-manager" 
  },
  { 
    title: "Weather Dashboard", 
    description: "Live weather tracking app using OpenWeather API.", 
    url: "https://github.com/barigyederek/weather-dashboard" 
  },
  { 
    title: "E-commerce Store", 
    description: "Full shopping platform with Stripe payment integration.", 
    url: "https://github.com/barigyederek/ecommerce-store" 
  },
  { 
    title: "Blog Platform", 
    description: "CMS-style blog with markdown support and comments.", 
    url: "https://github.com/barigyederek/blog-platform" 
  },
  { 
    title: "Fitness Tracker", 
    description: "Mobile-friendly app to log workouts and track progress.", 
    url: "https://github.com/barigyederek/fitness-tracker" 
  },
  { 
    title: "Movie Search Engine", 
    description: "Search and discover movies using TMDB API.", 
    url: "https://github.com/barigyederek/movie-search" 
  },
  { 
    title: "Password Manager", 
    description: "Secure password storage and generation tool.", 
    url: "https://github.com/barigyederek/password-manager" 
  },
  { 
    title: "Music Streaming App", 
    description: "Spotify-like interface for playing and managing music.", 
    url: "https://github.com/barigyederek/music-app" 
  },
  { 
    title: "Social Media Dashboard", 
    description: "Manage multiple social accounts from one dashboard.", 
    url: "https://github.com/barigyederek/social-dashboard" 
  },
  { 
    title: "Recipe Finder", 
    description: "Search recipes by ingredients with nutrition info.", 
    url: "https://github.com/barigyederek/recipe-finder" 
  },
  { 
    title: "Email Newsletter", 
    description: "Subscribe and manage email newsletters with automation.", 
    url: "https://github.com/barigyederek/newsletter" 
  },
  { 
    title: "Project Management Tool", 
    description: "Kanban board with drag-and-drop task management.", 
    url: "https://github.com/barigyederek/project-manager" 
  },
  { 
    title: "Analytics Dashboard", 
    description: "Real-time data visualization and reporting tool.", 
    url: "https://github.com/barigyederek/analytics" 
  },
  { 
    title: "Language Learning App", 
    description: "Interactive lessons and flashcards for language practice.", 
    url: "https://github.com/barigyederek/language-learn" 
  },
  { 
    title: "Expense Tracker", 
    description: "Track spending, categorize expenses, view reports.", 
    url: "https://github.com/barigyederek/expense-tracker" 
  },
  { 
    title: "Video Tutorial Library", 
    description: "Platform to upload, organize, and stream tutorial videos.", 
    url: "https://github.com/barigyederek/video-library" 
  },
  { 
    title: "Appointment Booking System", 
    description: "Schedule and manage appointments with automated reminders.", 
    url: "https://github.com/barigyederek/appointment-booking" 
  },
  { 
    title: "AI Chatbot", 
    description: "Intelligent chatbot with natural language processing.", 
    url: "https://github.com/barigyederek/ai-chatbot" 
  }
];
		<Header />
		<main>
			<h1>Projects</h1>
			<div class="projects-grid">
				{
					Array.from({ length: 20 }).map((_, index) => (
						<article class="project-card">
							<a href="https://github.com/barigyederek" target="_blank" rel="noopener noreferrer">
								<h3 class="project-title">Project {index + 1}</h3>
								<p class="project-description">A cool project that I built. Click to view on GitHub.</p>
							</a>
						</article>
					))
				}
			</div>
		</main>
		<Footer />
	</body>
</html>
